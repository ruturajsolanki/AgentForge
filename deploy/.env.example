# ── Required for NVIDIA NIM (cloud mode, build.nvidia.com) ────────────
NIM_API_KEY=nvapi-xxx-from-build.nvidia.com
FORGEOS_PROVIDER=nim
FORGEOS_API_BASE=https://integrate.api.nvidia.com/v1
FORGEOS_MODEL=meta/llama-3.3-70b-instruct
FORGEOS_CODE_MODEL=qwen/qwen2.5-coder-32b-instruct
FORGEOS_PLANNER_MODEL=meta/llama-3.3-70b-instruct
FORGEOS_LONGCTX_MODEL=zai-org/GLM-4.6

# ── Optional: self-hosted NIM / vLLM ──────────────────────────────────
# NGC_API_KEY=...                # for pulling nvcr.io/nim/* images
# VLLM_API_BASE=http://vllm:8000/v1
# HF_TOKEN=...                   # to download GLM weights for vLLM

# ── Auth ──────────────────────────────────────────────────────────────
FORGEOS_DEV_AUTH_BYPASS=true
# CLERK_JWKS_URL=https://<your-app>.clerk.accounts.dev/.well-known/jwks.json
# CLERK_JWT_ISSUER=https://<your-app>.clerk.accounts.dev
